# ============================================================================
# Environment Variable Configuration File - Simplified
# Purpose: Configuration for test scripts under tests/ directory
# Usage:
#   1. Copy this file to .env
#   2. Fill in actual environment variable values
#   3. Load environment variables: set -a && source .env && set +a
#   4. Run test script: ./run-tests.sh
# ============================================================================

# ============================================================================
# Required Environment Variables (must be filled)
# ============================================================================

# ---- Account Configuration ----
# Source Account ID (current Alibaba Cloud account ID)
# How to find: Log in to Alibaba Cloud Console -> Account ID in top-right corner
SOURCE_ACCOUNT_ID=

# Alibaba Cloud Region ID (for KMS API endpoint, e.g., cn-hangzhou, cn-shanghai)
REGION=cn-hangzhou

# ---- Kubernetes Configuration ----
# Kubernetes Cluster ID (used for RRSA configuration)
# How to find: Log in to ACK Console -> Cluster List -> Cluster ID
CLUSTER_ID=

# ============================================================================
# Optional Environment Variables (fill based on test requirements)
# ============================================================================

# ---- Test Configuration ----
# Test namespace (default: staging)
NAMESPACE=staging

# Test timeout in seconds (default: 180)
TEST_TIMEOUT=180

# Skip test cases (comma-separated)
# Example: SKIP_TESTS=TC-005,TC-006 to skip AK/SK and cross-account tests
SKIP_TESTS=

# ---- AK/SK Configuration (source account, for RAM/KMS API calls) ----
# Used by test script to create temporary RAM Users, Policies, etc.
# TC-003/TC-004/TC-005 dynamically create their own RAM Users and obtain AK/SK from this account
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
# ---- KMS Configuration ----
# KMS encryption key ID (for DKMS/managed KMS scenarios, leave empty for default CMK)
ENCRYPTION_KEY_ID=
# DKMS instance ID (for DKMS/managed KMS scenarios, leave empty for default)
DKMS_INSTANCE_ID=

# ---- Cross-Account Test Configuration (required for TC-006) ----
# Target Account ID (used for cross-account testing)
# Notes:
#   - If set with TARGET_ACCOUNT_ACCESS_KEY_ID and TARGET_ACCOUNT_ACCESS_KEY_SECRET,
#     the script will automatically create RAM Role, RAM Policy, and KMS Secret in target account
#   - If left empty, cross-account tests will be skipped
TARGET_ACCOUNT_ID=

# Target Account AccessKey ID (for auto-creating cross-account resources)
# The AK/SK must have permissions to create RAM Role, RAM Policy, and KMS Secret
TARGET_ACCOUNT_ACCESS_KEY_ID=
# Target Account AccessKey Secret
TARGET_ACCOUNT_ACCESS_KEY_SECRET=
# Target Account KMS Configuration (for DKMS scenarios)
# If target account uses DKMS (Dedicated KMS), specify these parameters
TARGET_ACCOUNT_ENCRYPTION_KEY_ID=
TARGET_ACCOUNT_DKMS_INSTANCE_ID=
TARGET_ACCOUNT_REGION_ID=

# ---- OIDC Configuration ----
# OIDC Provider ARN (usually auto-constructed from SOURCE_ACCOUNT_ID + CLUSTER_ID, typically no manual setup needed)
OIDC_PROVIDER_ARN=

# OIDC Issuer URL (optional, overrides auto-detection from cluster API)
# If set, this URL is used directly for RRSA trust policy oidc:iss condition.
# If not set, the test framework queries the cluster API (with retry) to obtain the issuer URL.
# Example: https://oidc-ack-cn-hangzhou.oss-cn-hangzhou.aliyuncs.com/<cluster-id>
OIDC_ISSUER_URL=

# ---- Automation Controls ----
# Skip Provider auto-deployment (default: false)
# Set to true if Provider is already deployed or you want to skip auto-install
SKIP_PROVIDER_DEPLOY=false

# Auto-cleanup KMS Secrets after tests (default: true)
AUTO_CLEANUP_KMS=true

# Auto-cleanup RAM resources after tests (default: true)
AUTO_CLEANUP_RAM=true

# ============================================================================
# Usage Instructions
# ============================================================================
#
# Quick Start:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env file and fill in required environment variables (SOURCE_ACCOUNT_ID and CLUSTER_ID)
#   3. Load environment variables (important! use set -a to ensure variables are exported):
#      set -a && source .env && set +a
#   4. Run tests: ./run-tests.sh
#
# Test Case Description (ordered by authentication chain priority):
#   TC-001: Pod SA RRSA Authentication
#           Uses Pod ServiceAccount OIDC Token for authentication
#           Needs: SOURCE_ACCOUNT_ID + CLUSTER_ID
#   TC-002: Provider RRSA Authentication
#           Uses Provider Pod OIDC Token for authentication
#           Needs: SOURCE_ACCOUNT_ID + CLUSTER_ID
#   TC-003: RAM Role Authentication (AK/SK + AssumeRole)
#           Dynamically creates a temporary RAM User, obtains AK/SK, then uses AssumeRole for auth
#           Needs: ALIBABA_ACCESS_KEY_ID + ALIBABA_ACCESS_KEY_SECRET (for RAM API calls)
#   TC-004: Node Publish Secret Authentication
#           Dynamically creates a temporary RAM User, configures nodePublishSecret for auth
#           Needs: ALIBABA_ACCESS_KEY_ID + ALIBABA_ACCESS_KEY_SECRET (for RAM API calls)
#   TC-005: AK/SK Authentication
#           Dynamically creates a temporary RAM User, obtains AK/SK, configures DaemonSet for auth
#           Needs: ALIBABA_ACCESS_KEY_ID + ALIBABA_ACCESS_KEY_SECRET (for RAM API calls)
#   TC-006: Cross-Account Authentication
#           Dynamically creates temporary RAM Users in both source and target accounts
#           Needs: ALIBABA_ACCESS_KEY_ID + ALIBABA_ACCESS_KEY_SECRET + TARGET_ACCOUNT_* config
#   TC-007: ECS RAM Role Authentication
#           Uses ECS instance metadata service (requires Worker nodes with RAM Role attached)
#           Needs: CLUSTER_ID (auto-detects WorkerRole from cluster)
#   TC-008: JMESPath JSON Parsing (functional test, uses AK/SK auth)
#   TC-009: Secret Rotation (functional test, uses AK/SK auth)
#   TC-010: K8s Secret Sync / secretObjects (functional test, uses AK/SK auth)
#   TC-011: Post-deployment Secret Cleanup (functional test, uses AK/SK auth)
#
# Common Scenarios:
#
# 1. Basic RRSA Test (TC-001 + TC-002):
#    Only fill in: SOURCE_ACCOUNT_ID, CLUSTER_ID
#
# 2. Full Test (all TCs):
#    Fill in all environment variables
#
# 3. Skip certain tests:
#    Set: SKIP_TESTS=TC-005,TC-006
#
# Example:
#   # Load environment variables
#   set -a && source .env && set +a
#
#   # Verify environment variables
#   echo $SOURCE_ACCOUNT_ID
#   echo $CLUSTER_ID
#
#   # Run tests
#   ./run-tests.sh
#
# Troubleshooting:
#   - If tests fail, check log files under test-logs-*/ directory
#   - If RRSA authentication fails, verify SOURCE_ACCOUNT_ID and CLUSTER_ID are correct
#   - If RAM API calls fail, verify ALIBABA_ACCESS_KEY_ID and ALIBABA_ACCESS_KEY_SECRET are valid
#   - If cross-account tests fail, verify TARGET_ACCOUNT_* credentials have sufficient permissions
#
# ============================================================================
